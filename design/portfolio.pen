                  "children": [
                    {
                      "type": "text",
                      "id": "IzjnD",
                      "name": "About / Paragraph 1",
                      "fill": "$muted",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "I design and build AI-powered systems that automate business operations, connect existing tools, and turn complex processes into reliable workflows.",
                      "lineHeight": 1.6,
                      "fontFamily": "$font-body",
                      "fontSize": 20,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "s9F5a",
                      "name": "About / Paragraph 2",
                      "fill": "$muted",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Coming from a 6-year background in backend software engineering (.NET/C#), I approach automation like software development—not as isolated workflows, but as maintainable systems. I prioritize clean architecture, reusable components, API-first integrations, robust error handling, and clear documentation.",
                      "lineHeight": 1.6,
                      "fontFamily": "$font-body",
                      "fontSize": 20,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "c0JGE",
                      "name": "About / Paragraph 3",
                      "fill": "$muted",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "My current focus is on AI agents, LLM workflows, API integrations, and workflow orchestration. Whether it's automating operations, building internal AI tools, or integrating language models into existing products, I enjoy solving real business problems with practical engineering.",
                      "lineHeight": 1.6,
                      "fontFamily": "$font-body",
                      "fontSize": 20,
                      "fontWeight": "normal"
